      "name": "NumberToWordConvert",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "pm.test(\"validate the status code of soap api xml response\", function(){\r",
              "\r",
              "     pm.response.to.have.status(200);\r",
              "\r",
              "})\r",
              "\r",
              "pm.test(\"validate the number into words in response\",()=>{\r",
              "\r",
              "     const jsResponse = xml2Json(pm.response.text());\r",
              "     console.log(jsResponse);\r",
              "   \r",
              "     pm.expect(jsResponse[\"soap:Envelope\"][\"soap:Body\"][\"m:NumberToWordsResponse\"]\r",
              "               [\"m:NumberToWordsResult\"]).to.eql(pm.collectionVariables.get(\"responseNumber\"));\r",
              "\r",
              "})\r",
              "\r",
              "pm.test(\"validate whether expected text is available in response or not \",()=>{\r",
              "    pm.expect(pm.response.text()).to.include(pm.collectionVariables.get(\"responseNumber\"));\r",
              "})\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
