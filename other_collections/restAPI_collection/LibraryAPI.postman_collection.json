      "name": "GetBook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "const jsonResponse = pm.response.json();\r",
              "\r",
              "const expectedSchema= {\r",
              "\r",
              "  \"type\": \"array\",\r",
              "  \"items\": {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "      \"name\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"isbn\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"aisle\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"author\": {\r",
              "        \"type\": \"string\"\r",
              "      }\r",
              "    },\r",
              "    \"required\": [\r",
              "      \"name\",\r",
              "      \"isbn\",\r",
              "      \"aisle\",\r",
              "      \"author\"\r",
              "    ]\r",
              "  }\r",
              "};\r",
              "\r",
              "\r",
              "pm.test(\"validat the json response it should as it as we send in post request\",()=>{\r",
              "   \r",
              "   console.log(jsonResponse);\r",
              "\r",
              "   pm.expect( jsonResponse[0].author).to.eql(pm.collectionVariables.get(\"author\"));\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"response json schema validation\" , function(){\r",
              " \r",
              "     pm.response.to.have.jsonSchema(expectedSchema);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
