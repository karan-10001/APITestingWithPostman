  "item": [
    {
      "name": "AddBook",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "const resJsonData = response;\r",
              "console.log(response);\r",
              "console.log(response.ID);\r",
              "pm.collectionVariables.set(\"bookID\",response.ID);\r",
              "\r",
              "pm.test(\"validate the status \", function(){\r",
              "\r",
              "    pm.response.to.have.status(200);\r",
              "\r",
              "    pm.expect(response).to.have.property(\"Msg\"); \r",
              "\r",
              "    pm.expect(response.Msg).to.eql(\"successfully added\"); \r",
              "    \r",
              "});\r",
              "\r",
              "function generateBookId(){\r",
              "\r",
              "   let reqBody = Json.parse(pm.request.body.raw);\r",
              "   let isbn_Id = reqBody.isbn;\r",
              "   let aisle_Id = reqBody.aisle;\r",
              "\r",
              "   let book_ID= isbn_Id+aisle_Id;\r",
              "\r",
              "   return book_ID;\r",
              "    \r",
              "}\r",
              "\r",
              "function cleanupScript()\r",
              "{\r",
              "    pm.collectionVariables.set(\"bookID\",generateBookId());\r",
              "    pm.execution.setNextRequest(\"DeleteBook\");\r",
              "\r",
              "}\r",
              "\r",
              "pm.test(\"headers , cookies & response time validation\", ()=>{\r",
              "\r",
              "//error handling scenario , like if isbn become duplicate \r",
              "   try{\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.eql(\"application/json;charset=UTF-8\");\r",
              "\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1200);\r",
              "\r",
              "    pm.expect(pm.response.text()).to.include(\"successfully added\");\r",
              "   }\r",
              "   catch(err)\r",
              "   {\r",
              "       if(resJsonData.msg.includes(\"exists\"))\r",
              "       {\r",
              "          cleanupScript();\r",
              "\r",
              "       }\r",
              "   }\r",
              "});\r",
              "\r",
              "pm.test(\"ID logic validation\", function(){\r",
              "\r",
              " const isbn_val=pm.collectionVariables.get(\"isbn\");\r",
              "\r",
              " const reqeustBodyRaw = pm.request.body.raw;\r",
              " const reqeustBodyJson = JSON.parse(reqeustBodyRaw);\r",
              "// const reqeustBodyJson = JSON.parse(pm.request.body.raw);\r",
              "\r",
              " const aisle_val= reqeustBodyJson.aisle;\r",
              " const expectedID= isbn_val +aisle_val;\r",
              " pm.expect(expectedID).to.eql(response.ID);\r",
              "\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "\r",
              "const code = pm.globals.get(\"companyCode\");\r",
              "const var1 = pm.variables.replaceIn(\"{{$randomInt}}\");\r",
              "//console.log(code+var1);\r",
              "const var2= code+var1;\r",
              "pm.collectionVariables.set(\"isbn\", var2);\r",
              "\r",
              "pm.collectionVariables.set(\"book_Name\",pm.iterationData.get(\"BookName\"));\r",
              "console.log(pm.collectionVariables.get(\"book_Name\"));\r",
              "pm.collectionVariables.set(\"author\",pm.iterationData.get(\"Author\"));\r",
              "console.log(pm.collectionVariables.get(\"author\"));\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\"name\":\"{{book_Name}}\",\r\n\"isbn\":\"wert3\",\r\n\"aisle\":\"klsslts231\",\r\n\"author\":\"{{author}}\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
